generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN

  @@map("users_role")
}

enum WorkStatus {
  READY
  NOT_READY

  @@map("work_status")
}

model User {
  id        String   @id @default(dbgenerated("(uuid())")) @db.VarChar(36)
  email     String   @unique @db.VarChar(255)
  name      String   @db.VarChar(255)
  avatar    String?  @db.VarChar(500)
  googleId  String?  @unique @map("google_id") @db.VarChar(255)
  role      Role     @default(USER)
  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt DateTime @default(now()) @map("updated_at") @db.DateTime(0)

  @@map("users")
}

model Project {
  id          String   @id @default(dbgenerated("(uuid())")) @db.VarChar(36)
  name        String   @db.VarChar(255)
  description String   @db.Text
  image       String?  @db.VarChar(500)
  productLink String?  @map("product_link") @db.VarChar(500)
  githubLink  String?  @map("github_link") @db.VarChar(500)
  createdAt   DateTime @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt   DateTime @default(now()) @map("updated_at") @db.DateTime(0)

  @@map("projects")
}

model AdminProfile {
  id         String     @id @default(dbgenerated("(uuid())")) @db.VarChar(36)
  name       String     @db.VarChar(255)
  position   String     @db.VarChar(255)
  bio        String     @db.Text
  skills     Json       @default(dbgenerated("(json_array())"))
  workStatus WorkStatus @default(NOT_READY) @map("work_status")
  createdAt  DateTime   @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt  DateTime   @default(now()) @map("updated_at") @db.DateTime(0)

  @@map("admin_profiles")
}

model Skill {
  id        String   @id @default(dbgenerated("(uuid())")) @db.VarChar(36)
  name      String   @db.VarChar(255)
  image     String?  @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt DateTime @default(now()) @map("updated_at") @db.DateTime(0)

  @@map("skills")
}

model Experience {
  id          String   @id @default(dbgenerated("(uuid())")) @db.VarChar(36)
  name        String   @db.VarChar(255)
  description String   @db.Text
  startDate   String @db.VarChar(255)
  endDate     String? @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt   DateTime @default(now()) @map("updated_at") @db.DateTime(0)

  @@map("experiences")
}

model Contact {
  id        String   @id @default(dbgenerated("(uuid())")) @db.VarChar(36)
  name      String   @db.VarChar(255)
  link      String   @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt DateTime @default(now()) @map("updated_at") @db.DateTime(0)

  @@map("contacts")
}